  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "tsc && node --test dist/test/schema.test.js dist/test/loader.test.js dist/test/graph.test.js dist/test/mcp.test.js dist/test/writer.test.js dist/test/serializer.test.js dist/test/web.test.js",
